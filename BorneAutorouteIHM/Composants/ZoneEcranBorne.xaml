<UserControl x:Class="BorneAutorouteIHM.Composants.ZoneEcranBorne"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BorneAutorouteIHM.Composants"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="375"
             >
    <Grid x:Name="PanelFond" Margin="10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <DockPanel x:Name="PanelTitre" Grid.Row="0" Margin="10,0">
            <Label x:Name="LabelNumeroEtape" HorizontalAlignment="Left" FontSize="75" FontFamily="Roboto" FontWeight="Bold" DockPanel.Dock="Top" Margin="0,-10,0,-30"/>
            <Viewbox StretchDirection="DownOnly" HorizontalAlignment="Left">
                <Label x:Name="LabelNomEtape" FontSize="60" FontFamily="Roboto" FontWeight="Bold"/>
            </Viewbox>
        </DockPanel>
        <Grid x:Name="PanelContenu" Grid.Row="1">
            
        </Grid>
    </Grid>
</UserControl>
