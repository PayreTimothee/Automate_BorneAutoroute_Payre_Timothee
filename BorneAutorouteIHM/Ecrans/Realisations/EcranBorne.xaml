<ecrans:Ecran  xmlns:ecrans="clr-namespace:BorneAutorouteIHM.Ecrans"
             x:Class="BorneAutorouteIHM.Ecrans.Realisations.EcranBorne"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BorneAutorouteIHM.Ecrans.Realisations"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Viewbox>
        <Grid x:Name="PanelFond" Height="900" Width="1600">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <Grid x:Name="PanelMessage" Grid.Row="0">
                <Border x:Name="BorderZoneAffichage" BorderThickness="5" Height="100" Width="900">
                    <TextBlock x:Name="ZoneAffichage" FontSize="40" FontFamily="Roboto" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Message}"></TextBlock>
                </Border>
                </Grid>
            <Canvas x:Name="PanelFront" Panel.ZIndex="1" Grid.Row="1" Grid.RowSpan="2">
                
            </Canvas>
            <Grid x:Name="PanelZones" Grid.Row="1" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            </Grid>
            <Grid x:Name="PanelBas" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </Grid>
    </Viewbox>
</ecrans:Ecran>
